# Telegram Bot Token (отримати у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ManageEngine ServiceDesk Plus
SDP_URL=https://helpme.gkfs.com.ua
SDP_API_KEY=your_technician_key_here
# Ігнорувати перевірку SSL (true якщо самопідписаний сертифікат)
SDP_SSL_VERIFY=true

# Режим доступу: general (відкритий) або restricted (з паролем)
ACCESS_MODE=restricted
ACCESS_PASSWORD=your_secret_password_here

# Максимальна кількість фото на заявку
MAX_PHOTOS=5
